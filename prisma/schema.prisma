generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  services Service[]
}

model Service {
  id         Int      @id @default(autoincrement())
  name       String
  duration   Int
  price      Float
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
}

model Client {
  id           String        @id @default(uuid())
  name         String
  phone        String        @unique
  email        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tags         String?
  appointments Appointment[]
}

model Appointment {
  id           String   @id @default(uuid())
  date         DateTime
  status       String   @default("CONFIRMED")
  serviceName  String
  servicePrice Float    @default(0)
  duration     Int      @default(30)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  clientId     String
  notes        String?
  client       Client   @relation(fields: [clientId], references: [id])
}

model ClinicSettings {
  id            Int      @id @default(1)
  name          String   @default("Clínica Demo")
  logoUrl       String?
  address       String   @default("Calle Ejemplo 123")
  phone         String   @default("+34 600 000 000")
  assistantName String   @default("Ana (IA Clínica)")
  isBotActive   Boolean  @default(true)
  availability     Json?
  appointmentRules Json?
  adminUsername    String   @default("admin")
  adminPassword    String   @default("admin123")
  updatedAt        DateTime @updatedAt
}
